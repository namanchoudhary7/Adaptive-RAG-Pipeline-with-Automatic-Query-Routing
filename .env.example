# ==========================================
# Adaptive RAG Environment Configuration
# Copy this file to .env and fill in your keys
# ==========================================

# --- Local LLM (Ollama) ---
# Used as a fallback or alternative local model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Embedding Model (HuggingFace Local) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# --- Vector Database (ChromaDB) ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=techdocs
DOCS_DIR=./data/docs

# --- RAG Pipeline Tuning ---
TOP_K=5
MAX_RETRY_LOOPS=2

# --- API Keys ---
USER_AGENT="my-adaptive-rag-app"
HUGGINGFACEHUB_API_TOKEN=""

# Required for the main generator and grader
# Get yours for free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Offline Mode Locks ---
# Leave these as 0 for your first run so the models can download.
# Change them to 1 after running setup.py for instant local startups.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0